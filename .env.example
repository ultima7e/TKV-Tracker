# Copy this file to ".env" and fill in your real values.
# .env is git-ignored — it never leaves your machine.
#
# NUTSTORE_USER:      your Nutstore account email
# NUTSTORE_PASSWORD:  an APP password from Nutstore (Account -> Security ->
#                     Third-party application management), NOT your login password
# NUTSTORE_FILE_PATH: path of the Excel under your Nutstore root,
#                     e.g. ProjectData/tracker.xlsx

NUTSTORE_USER=you@example.com
NUTSTORE_PASSWORD=your-app-password-here
NUTSTORE_FILE_PATH=ProjectData/tracker.xlsx
